{
  "extends": "@sindresorhus/tsconfig",
  "include": [
    "./*.ts",
    "./src/*.ts",
    "./scripts/*.ts",
    "./tests/**/*.ts",
    "./typings"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "sourceRoot": ".",
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "erasableSyntaxOnly": false,
    "esModuleInterop": true,
    "strict": true,
    "isolatedModules": true,
    "composite": true,
    "verbatimModuleSyntax": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "paths": {
      "reactive-vscode": [
        "./node_modules/reactive-vscode/dist/index.d.ts"
      ],
      "vitest": [
        "./node_modules/vitest/dist/index.d.ts"
      ]
    }
  }
}

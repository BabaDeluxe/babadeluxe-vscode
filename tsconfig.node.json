{
  "extends": "@sindresorhus/tsconfig",
  "include": [
    "./src/**/*.ts",
    "./vite.config.ts",
    "./vitest.config.ts",
    "./xo.config.ts",
    "./*.ts",
    "./scripts/*.ts",
    "./tests/**/*.ts",
    "./typings",
  ],
  "compilerOptions": {
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "erasableSyntaxOnly": false,
    "esModuleInterop": true,
    "strict": true,
    "composite": true,
    "incremental": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "reactive-vscode": [
        "node_modules/reactive-vscode/dist/index.d.ts"
      ],
      "vitest": [
        "node_modules/vitest/dist/index.d.ts"
      ]
    }
  }
}
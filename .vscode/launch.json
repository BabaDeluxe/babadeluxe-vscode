{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build + Debug",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "npm: build:full",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*"]
    },
    {
      "name": "Debug",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*"]
    }
  ]
}

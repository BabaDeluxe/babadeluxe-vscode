{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build + Debug",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "npm: build:full",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*"
      ]
    },
    {
      "name": "Watch + Debug",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "sourceMaps": true,
      "preLaunchTask": "Start Dev Watchers"
    }
  ]
}
